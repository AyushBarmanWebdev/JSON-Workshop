---
// src/components/Workspace.astro
---

<div class="flex flex-col h-[calc(100vh-3.5rem)] bg-canvas text-ink transition-colors duration-200" id="main-content">
  <h1 class="sr-only">JSON Workshop - Free JSON Formatter & Validator</h1>
  <!-- Toolbar -->
  <div class="flex flex-row items-center justify-between gap-4 px-6 py-3 border-b border-hairline bg-cloud select-none transition-colors duration-200 overflow-x-auto whitespace-nowrap scrollbar-none h-14 min-h-[3.5rem] flex-nowrap shrink-0">
    <!-- Operations Group -->
    <div class="flex items-center gap-2 flex-nowrap">
      <button 
        id="btn-format" 
        class="bg-primary hover:bg-primary-bright active:bg-primary-deep text-on-primary font-bold text-xs tracking-wider uppercase px-4 py-2 h-9 rounded-md cursor-pointer transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-primary-bright focus-visible:outline-none flex items-center justify-center shrink-0"
        title="Format & Validate JSON (Ctrl + Enter)"
      >
        Format & Validate
      </button>

      <button 
        id="btn-minify" 
        class="bg-canvas text-ink hover:bg-cloud border border-hairline active:bg-fog font-bold text-xs tracking-wider uppercase px-4 py-2 h-9 rounded-md cursor-pointer transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none flex items-center justify-center shrink-0"
        title="Minify JSON (Ctrl + Shift + M)"
      >
        Minify
      </button>

      <!-- Indentation selector -->
      <div class="relative flex items-center shrink-0">
        <label for="indent-select" class="sr-only">Indentation spacing</label>
        <select 
          id="indent-select" 
          class="bg-canvas text-ink border border-hairline text-xs font-semibold px-3 py-2 pr-8 h-9 rounded-md cursor-pointer appearance-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none transition-colors duration-150"
        >
          <option value="2">2 Spaces</option>
          <option value="4">4 Spaces</option>
          <option value="tab">Tab Indent</option>
        </select>
        <div class="absolute right-3 pointer-events-none text-graphite">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </div>
    </div>

    <!-- Actions Group -->
    <div class="flex items-center gap-2 flex-nowrap">
      <button 
        id="btn-sample" 
        class="bg-canvas text-ink hover:bg-cloud border border-hairline active:bg-fog font-bold text-xs tracking-wider uppercase px-3 py-2 h-9 rounded-md cursor-pointer transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none flex items-center gap-1.5"
        title="Load Sample JSON"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Load Sample
      </button>

      <button 
        id="btn-upload" 
        class="bg-canvas text-ink hover:bg-cloud border border-hairline active:bg-fog font-bold text-xs tracking-wider uppercase px-3 py-2 h-9 rounded-md cursor-pointer transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none flex items-center gap-1.5"
        title="Upload File (.json)"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
        </svg>
        Upload File
      </button>
      <input type="file" id="file-input" accept=".json,application/json" class="hidden" aria-label="Upload JSON file" />

      <button 
        id="btn-copy" 
        class="bg-canvas text-ink hover:bg-cloud border border-hairline active:bg-fog font-bold text-xs tracking-wider uppercase px-3 py-2 h-9 rounded-md cursor-pointer transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none flex items-center gap-1.5"
        title="Copy Output (Ctrl + Shift + C)"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
        </svg>
        Copy Output
      </button>

      <button 
        id="btn-download" 
        class="bg-canvas text-ink hover:bg-cloud border border-hairline active:bg-fog font-bold text-xs tracking-wider uppercase px-3 py-2 h-9 rounded-md cursor-pointer transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none flex items-center gap-1.5"
        title="Download File (.json)"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        Download File
      </button>

      <div class="h-6 w-px bg-hairline-strong mx-1 hidden sm:block"></div>

      <button 
        id="btn-clear" 
        class="bg-canvas text-error hover:bg-bloom-rose border border-error/20 active:bg-bloom-rose font-bold text-xs tracking-wider uppercase px-3 py-2 h-9 rounded-md cursor-pointer transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-error focus-visible:outline-none flex items-center gap-1.5"
        title="Clear editors"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
        Clear
      </button>
    </div>
  </div>

  <!-- Concise Hero & Trust Header -->
  <div class="px-6 py-3 border-b border-hairline bg-paper flex flex-col md:flex-row md:items-center justify-between gap-3 select-none transition-colors duration-200 min-h-[4.5rem]">
    <div class="space-y-0.5">
      <h2 class="text-sm font-bold text-ink tracking-tight font-sans">
        Fast JSON Formatter & Validator
      </h2>
      <p class="text-[11px] text-charcoal font-sans leading-relaxed max-w-2xl">
        Format, validate and minify JSON instantly. Everything runs locally in your browser. Your data never leaves your device.
      </p>
    </div>

    <!-- Trust Badges Group -->
    <div class="flex flex-wrap items-center gap-2">
      <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[11px] font-bold bg-emerald-50 text-emerald-800 border border-emerald-300 dark:bg-emerald-950/80 dark:text-emerald-300 dark:border-emerald-800/80 select-none">
        <span class="text-emerald-600 dark:text-emerald-400 font-bold">✓</span>
        100% Client-side Privacy
      </span>
      <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[11px] font-bold bg-blue-50 text-blue-900 border border-blue-300 dark:bg-blue-950/80 dark:text-blue-300 dark:border-blue-800/80 select-none">
        <span class="text-blue-700 dark:text-blue-400 font-bold">✓</span>
        Offline Ready
      </span>
      <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[11px] font-bold bg-slate-100 text-slate-900 border border-slate-300 dark:bg-slate-800/80 dark:text-slate-200 dark:border-slate-700 select-none">
        <span class="text-slate-700 dark:text-slate-400 font-bold">✓</span>
        Free Forever
      </span>
    </div>
  </div>

  <!-- Workspace Splits -->
  <div class="flex-1 flex flex-col md:flex-row overflow-hidden divide-y md:divide-y-0 md:divide-x divide-hairline">
    <!-- Left Editor (Input) -->
    <div class="flex-1 flex flex-col h-1/2 md:h-full min-w-0 relative">
      <div class="px-4 py-2 text-xxs font-semibold uppercase tracking-widest text-graphite border-b border-hairline bg-cloud/50 flex items-center justify-between select-none transition-colors duration-200">
        <span>Input JSON</span>
        <span id="input-stats" class="normal-case font-medium font-mono text-graphite">0 chars</span>
      </div>
      <!-- Monaco Container -->
      <div class="flex-1 w-full relative overflow-hidden" id="editor-input-container">
        <div id="monaco-input" class="absolute inset-0 w-full h-full"></div>
        <div class="absolute inset-0 flex items-center justify-center bg-canvas pointer-events-none transition-opacity duration-300" id="input-loading">
          <span class="text-xs text-graphite animate-pulse">Loading Editor…</span>
        </div>
        <!-- Input Empty State Placeholder Overlay -->
        <div class="absolute inset-0 flex flex-col items-center justify-center bg-canvas select-none pointer-events-none p-6 text-center transition-all duration-300 opacity-0 hidden" id="input-placeholder">
          <span class="text-graphite/40 font-bold text-xl mb-1">{`{ }`}</span>
          <p class="text-xs text-graphite/50 max-w-[240px] leading-relaxed font-sans">Paste or drop JSON here...</p>
        </div>
      </div>
    </div>

    <!-- Right Editor (Output) -->
    <div class="flex-1 flex flex-col h-1/2 md:h-full min-w-0 relative">
      <div class="px-4 py-2 text-xxs font-semibold uppercase tracking-widest text-graphite border-b border-hairline bg-cloud/50 flex items-center justify-between select-none transition-colors duration-200">
        <span>Formatted Output</span>
        <span id="output-stats" class="normal-case font-medium font-mono text-graphite">0 chars</span>
      </div>
      <!-- Monaco Container -->
      <div class="flex-1 w-full relative overflow-hidden" id="editor-output-container">
        <div id="monaco-output" class="absolute inset-0 w-full h-full"></div>
        <div class="absolute inset-0 flex items-center justify-center bg-canvas pointer-events-none transition-opacity duration-300" id="output-loading">
          <span class="text-xs text-graphite animate-pulse">Loading Editor…</span>
        </div>
        <!-- Output Empty State Placeholder Overlay -->
        <div class="absolute inset-0 flex flex-col items-center justify-center bg-canvas select-none pointer-events-none p-6 text-center transition-all duration-300 opacity-100" id="output-placeholder">
          <span class="text-graphite/40 font-bold text-xl mb-1">{`{ }`}</span>
          <p class="text-xs text-graphite/50 max-w-[240px] leading-relaxed font-sans">Formatted JSON will appear here.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Status Bar -->
  <footer class="h-8 border-t border-hairline bg-paper flex items-center justify-between px-6 select-none transition-colors duration-200 text-xs font-medium">
    <div class="flex items-center gap-3">
      <!-- Status Badge -->
      <div id="status-badge" class="flex items-center gap-1.5 text-graphite" aria-live="polite" aria-atomic="true">
        <span class="w-2.5 h-2.5 rounded-full bg-steel inline-block" id="status-dot"></span>
        <span id="status-text">Ready</span>
      </div>

      <!-- Error Location Link -->
      <button 
        id="error-jump" 
        class="hidden text-error hover:underline cursor-pointer items-center gap-1 focus-visible:outline-none"
        title="Jump to error line in editor"
      >
        <span id="error-details"></span>
      </button>
    </div>

    <!-- Position & Info -->
    <div class="flex items-center gap-4 text-graphite font-mono">
      <span class="text-[10px] bg-cloud border border-hairline px-2 py-0.5 rounded cursor-help select-none hover:text-ink hover:border-hairline-strong transition-colors hidden sm:inline" title="Monaco Editor traps the Tab key by default. Press Ctrl+M to toggle focus trapping off and allow tabbing to outer elements.">Tab Trapping Active (Ctrl+M)</span>
      <span id="editor-position" class="hidden sm:inline tabular-nums">Ln 1, Col 1</span>
      <span id="json-size" class="tabular-nums">Size: 0 B</span>
    </div>
  </footer>
</div>

<script>
  import loader from '@monaco-editor/loader';

  // Configure loader to fetch Monaco files locally from public/monaco/vs
  loader.config({ paths: { vs: '/monaco/vs' } });

  let editorInput: any = null;
  let editorOutput: any = null;
  let monacoInstance: any = null;

  // Initial state values
  const SAMPLE_JSON = {
    "name": "JSON Workshop",
    "version": "1.0.0",
    "description": "Production-ready developer tools platform",
    "homepage": "https://jsonworkshop.com",
    "private": true,
    "engines": {
      "node": ">=22.12.0"
    },
    "features": [
      "JSON Formatting",
      "Syntax Validation",
      "Fast Minification",
      "Fully Accessible UI",
      "Instant Theme Toggling"
    ],
    "contributors": [
      {
        "name": "Antigravity",
        "role": "AI Coding Assistant",
        "team": "Google DeepMind"
      }
    ],
    "settings": {
      "theme": "dark",
      "editor": {
        "tabSize": 2,
        "minimap": false,
        "wordWrap": "on"
      }
    }
  };

  const getThemeName = () => {
    return document.documentElement.classList.contains('dark') ? 'vs-dark' : 'vs';
  };

  // Helper to format file sizes
  const formatBytes = (bytes: number) => {
    if (bytes === 0) return '0 B';
    const k = 1024;
    const sizes = ['B', 'KB', 'MB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
  };

  const updateStats = () => {
    if (!editorInput) return;
    const content = editorInput.getValue();
    const bytes = new Blob([content]).size;
    
    // Update input character stats
    const inputStats = document.getElementById('input-stats');
    if (inputStats) {
      inputStats.textContent = `${content.length} chars`;
    }

    // Update size stats
    const sizeStats = document.getElementById('json-size');
    if (sizeStats) {
      sizeStats.textContent = `Size: ${formatBytes(bytes)}`;
    }
  };

  const updateOutputStats = () => {
    if (!editorOutput) return;
    const content = editorOutput.getValue();
    const outputStats = document.getElementById('output-stats');
    if (outputStats) {
      outputStats.textContent = `${content.length} chars`;
    }
  };

  // Live validator using JSON.parse and line calculation
  const validateAndFormat = (shouldFormat: boolean) => {
    if (!editorInput || !editorOutput) return;
    const rawVal = editorInput.getValue().trim();

    // Elements
    const badge = document.getElementById('status-badge');
    const dot = document.getElementById('status-dot');
    const text = document.getElementById('status-text');
    const jumpBtn = document.getElementById('error-jump');
    const errorDetails = document.getElementById('error-details');

    const placeholder = document.getElementById('output-placeholder');
    if (!rawVal) {
      // Empty state
      if (dot) dot.className = 'w-2.5 h-2.5 rounded-full bg-steel inline-block';
      if (text) text.textContent = 'Ready';
      if (badge) badge.className = 'flex items-center gap-1.5 text-graphite';
      if (jumpBtn) jumpBtn.classList.add('hidden');
      editorOutput.setValue('');
      updateOutputStats();
      if (placeholder) {
        placeholder.classList.remove('opacity-0', 'hidden');
        placeholder.classList.add('opacity-100');
      }
      return;
    }

    try {
      const parsed = JSON.parse(rawVal);
      
      // Success styling
      if (dot) dot.className = 'w-2.5 h-2.5 rounded-full bg-emerald-500 inline-block';
      if (text) text.textContent = 'Valid JSON';
      if (badge) badge.className = 'flex items-center gap-1.5 text-emerald-600 dark:text-emerald-400';
      if (jumpBtn) jumpBtn.classList.add('hidden');

      if (shouldFormat) {
        const indentSelect = document.getElementById('indent-select') as HTMLSelectElement;
        const indentVal = indentSelect ? indentSelect.value : '2';
        let space: string | number = 2;
        if (indentVal === '4') space = 4;
        if (indentVal === 'tab') space = '\t';

        const formatted = JSON.stringify(parsed, null, space);
        editorOutput.setValue(formatted);
        
        if (placeholder) {
          placeholder.classList.remove('opacity-100');
          placeholder.classList.add('opacity-0');
          setTimeout(() => placeholder.classList.add('hidden'), 300);
        }
      }
    } catch (err: any) {
      // Error details
      const msg = err.message;
      let line = 1;
      let col = 1;

      // Extract error position
      const posMatch = msg.match(/at position (\d+)/);
      if (posMatch) {
        const pos = parseInt(posMatch[1], 10);
        const textUpToErr = rawVal.slice(0, pos);
        const lines = textUpToErr.split('\n');
        line = lines.length;
        col = lines[lines.length - 1].length + 1;
      }

      // Syntax error regex match for Chrome/Edge or Firefox
      const lineMatch = msg.match(/at line (\d+) column (\d+)/);
      if (lineMatch) {
        line = parseInt(lineMatch[1], 10);
        col = parseInt(lineMatch[2], 10);
      }

      // Format clean message (remove prefix JSON.parse: and strip raw positions to prevent duplicate labels in UI)
      let cleanMsg = msg
        .replace(/^JSON\.parse:\s*/, '')
        .replace(/in JSON at position \d+(\s*\(line \d+ column \d+\))?/, '')
        .replace(/at position \d+(\s*\(line \d+ column \d+\))?/, '')
        .replace(/at line \d+ column \d+ of the JSON data/, '')
        .replace(/\(line \d+ column \d+\)/, '')
        .replace(/at line \d+ column \d+/, '')
        .trim();
      
      // Error styling
      if (dot) dot.className = 'w-2.5 h-2.5 rounded-full bg-error inline-block';
      if (text) text.textContent = 'Invalid JSON';
      if (badge) badge.className = 'flex items-center gap-1.5 text-error font-semibold';
      
      if (jumpBtn && errorDetails) {
        errorDetails.textContent = `• Error: ${cleanMsg} (Ln ${line}, Col ${col})`;
        jumpBtn.classList.remove('hidden');
        
        // Save coordinates on button dataset for jump handler
        jumpBtn.setAttribute('data-line', line.toString());
        jumpBtn.setAttribute('data-col', col.toString());
      }
    }

    updateOutputStats();
  };

  const minifyJSON = () => {
    if (!editorInput || !editorOutput) return;
    const rawVal = editorInput.getValue().trim();

    const badge = document.getElementById('status-badge');
    const dot = document.getElementById('status-dot');
    const text = document.getElementById('status-text');
    const jumpBtn = document.getElementById('error-jump');
    const errorDetails = document.getElementById('error-details');

    if (!rawVal) return;

    try {
      const parsed = JSON.parse(rawVal);
      
      // Success styling
      if (dot) dot.className = 'w-2.5 h-2.5 rounded-full bg-emerald-500 inline-block';
      if (text) text.textContent = 'Valid JSON (Minified)';
      if (badge) badge.className = 'flex items-center gap-1.5 text-emerald-600 dark:text-emerald-400';
      if (jumpBtn) jumpBtn.classList.add('hidden');

      const minified = JSON.stringify(parsed);
      editorOutput.setValue(minified);
      
      const placeholder = document.getElementById('output-placeholder');
      if (placeholder) {
        placeholder.classList.remove('opacity-100');
        placeholder.classList.add('opacity-0');
        setTimeout(() => placeholder.classList.add('hidden'), 300);
      }
    } catch (err: any) {
      // Re-trigger standard validation to display the error location
      validateAndFormat(false);
    }

    updateOutputStats();
  };

  const copyOutputToClipboard = () => {
    if (!editorOutput) return;
    const content = editorOutput.getValue();
    if (!content) return;

    navigator.clipboard.writeText(content).then(() => {
      const btnCopy = document.getElementById('btn-copy');
      if (btnCopy) {
        const originalHtml = btnCopy.innerHTML;
        btnCopy.innerHTML = `
          <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          Copied!
        `;
        btnCopy.classList.remove('border-hairline');
        btnCopy.classList.add('border-emerald-500/30', 'text-emerald-600', 'dark:text-emerald-400');
        
        setTimeout(() => {
          btnCopy.innerHTML = originalHtml;
          btnCopy.classList.add('border-hairline');
          btnCopy.classList.remove('border-emerald-500/30', 'text-emerald-600', 'dark:text-emerald-400');
        }, 2000);
      }
    });
  };

  // Main init logic
  const initMonaco = () => {
    // Locate target container elements
    const inputContainer = document.getElementById('monaco-input');
    const outputContainer = document.getElementById('monaco-output');
    if (!inputContainer || !outputContainer) return;

    loader.init().then((monaco) => {
      monacoInstance = monaco;

      // Define custom editor settings that match developer UI high-density aesthetics
      const sharedOptions = {
        language: 'json',
        automaticLayout: true,
        minimap: { enabled: false },
        fontSize: 13,
        lineHeight: 18,
        fontFamily: 'Consolas, Menlo, Monaco, "Courier New", monospace',
        fontLigatures: true,
        scrollBeyondLastLine: false,
        cursorBlinking: 'smooth',
        cursorSmoothCaretAnimation: 'on',
        tabSize: 2,
        renderLineHighlight: 'all' as const,
        scrollbar: {
          verticalScrollbarSize: 8,
          horizontalScrollbarSize: 8,
          useShadows: false
        },
        padding: { top: 12, bottom: 12 }
      };

      // Input Editor
      editorInput = monaco.editor.create(inputContainer, {
        ...sharedOptions,
        value: JSON.stringify(SAMPLE_JSON, null, 2),
        readOnly: false
      });

      // Output Editor
      editorOutput = monaco.editor.create(outputContainer, {
        ...sharedOptions,
        value: '',
        readOnly: true,
        domReadOnly: true
      });

      // Keyboard Command Bindings for Input/Output Editors
      const formatCmd = monaco.KeyMod.CtrlCmd | monaco.KeyCode.Enter;
      const minifyCmd = monaco.KeyMod.CtrlCmd | monaco.KeyMod.Shift | monaco.KeyCode.KeyM;
      const copyCmd = monaco.KeyMod.CtrlCmd | monaco.KeyMod.Shift | monaco.KeyCode.KeyC;

      editorInput.addCommand(formatCmd, () => validateAndFormat(true));
      editorInput.addCommand(minifyCmd, () => minifyJSON());
      editorInput.addCommand(copyCmd, () => copyOutputToClipboard());

      editorOutput.addCommand(formatCmd, () => validateAndFormat(true));
      editorOutput.addCommand(minifyCmd, () => minifyJSON());
      editorOutput.addCommand(copyCmd, () => copyOutputToClipboard());

      // Apply initial theme
      monaco.editor.setTheme(getThemeName());

      // Hide load screens
      document.getElementById('input-loading')?.classList.add('opacity-0');
      document.getElementById('output-loading')?.classList.add('opacity-0');
      setTimeout(() => {
        document.getElementById('input-loading')?.classList.add('hidden');
        document.getElementById('output-loading')?.classList.add('hidden');
      }, 300);

      // Perform initial format
      validateAndFormat(true);
      updateStats();

      // Listeners
      editorInput.onDidChangeModelContent(() => {
        updateStats();
        
        // Toggle input placeholder overlay
        const rawVal = editorInput.getValue().trim();
        const inPlaceholder = document.getElementById('input-placeholder');
        if (inPlaceholder) {
          if (!rawVal) {
            inPlaceholder.classList.remove('hidden');
            setTimeout(() => inPlaceholder.classList.add('opacity-100'), 50);
          } else {
            inPlaceholder.classList.remove('opacity-100');
            setTimeout(() => inPlaceholder.classList.add('hidden'), 300);
          }
        }

        // Live validation on change
        validateAndFormat(false);
      });

      editorInput.onDidChangeCursorPosition((e: any) => {
        const posEl = document.getElementById('editor-position');
        if (posEl) {
          posEl.textContent = `Ln ${e.position.lineNumber}, Col ${e.position.column}`;
          posEl.classList.remove('hidden');
        }
      });

      // Listen to system theme changes
      window.addEventListener('theme-changed', (e: any) => {
        const theme = e.detail.theme === 'dark' ? 'vs-dark' : 'vs';
        monaco.editor.setTheme(theme);
      });

      // Focus input editor immediately
      editorInput.focus();
    });
  };

  // Core setup UI triggers
  const setupTriggers = () => {
    // Format button click
    document.getElementById('btn-format')?.addEventListener('click', () => {
      validateAndFormat(true);
    });

    // Minify button click
    document.getElementById('btn-minify')?.addEventListener('click', () => {
      minifyJSON();
    });

    // Indent select change
    document.getElementById('indent-select')?.addEventListener('change', () => {
      validateAndFormat(true);
    });

    // Load sample
    document.getElementById('btn-sample')?.addEventListener('click', () => {
      if (editorInput) {
        const inPlaceholder = document.getElementById('input-placeholder');
        if (inPlaceholder) {
          inPlaceholder.classList.remove('opacity-100');
          inPlaceholder.classList.add('hidden');
        }
        editorInput.setValue(JSON.stringify(SAMPLE_JSON, null, 2));
        validateAndFormat(true);
        editorInput.focus();
      }
    });

    // Clear editors
    document.getElementById('btn-clear')?.addEventListener('click', () => {
      if (editorInput) {
        const inPlaceholder = document.getElementById('input-placeholder');
        if (inPlaceholder) {
          inPlaceholder.classList.remove('hidden');
          setTimeout(() => inPlaceholder.classList.add('opacity-100'), 50);
        }
        editorInput.setValue('');
        validateAndFormat(true);
        editorInput.focus();
      }
    });

    // File Upload trigger
    const fileInput = document.getElementById('file-input') as HTMLInputElement;
    document.getElementById('btn-upload')?.addEventListener('click', () => {
      fileInput?.click();
    });

    fileInput?.addEventListener('change', (e: any) => {
      const file = e.target.files?.[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = (event) => {
        const text = event.target?.result as string;
        if (editorInput) {
          editorInput.setValue(text);
          validateAndFormat(true);
          editorInput.focus();
        }
      };
      reader.readAsText(file);
      // Reset input value to allow uploading same file again
      fileInput.value = '';
    });

    // Copy to clipboard
    document.getElementById('btn-copy')?.addEventListener('click', () => {
      copyOutputToClipboard();
    });

    // Download formatted output file
    document.getElementById('btn-download')?.addEventListener('click', () => {
      if (!editorOutput) return;
      const content = editorOutput.getValue();
      if (!content) return;

      const blob = new Blob([content], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'formatted.json';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });

    // Error jump handler
    document.getElementById('error-jump')?.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLElement;
      const line = parseInt(target.getAttribute('data-line') || '1', 10);
      const col = parseInt(target.getAttribute('data-col') || '1', 10);

      if (editorInput && monacoInstance) {
        editorInput.setPosition({ lineNumber: line, column: col });
        editorInput.revealLineInCenter(line);
        editorInput.focus();
      }
    });

    // Drag & Drop File Upload
    const inputContainer = document.getElementById('editor-input-container');
    if (inputContainer) {
      // Create drag overlay element dynamically
      const dragOverlay = document.createElement('div');
      dragOverlay.className = 'absolute inset-0 border-2 border-dashed border-primary bg-primary/5 flex flex-col items-center justify-center pointer-events-none transition-opacity duration-200 opacity-0 z-50';
      dragOverlay.innerHTML = `
        <div class="flex flex-col items-center gap-2 text-primary font-sans select-none pointer-events-none">
          <svg class="w-8 h-8 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
          </svg>
          <span class="text-xs font-bold uppercase tracking-wider">Drop JSON file here</span>
        </div>
      `;
      inputContainer.appendChild(dragOverlay);

      // Drag event listeners
      inputContainer.addEventListener('dragover', (e) => {
        e.preventDefault();
        e.stopPropagation();
        dragOverlay.classList.remove('opacity-0', 'hidden');
        dragOverlay.classList.add('opacity-100');
      });

      inputContainer.addEventListener('dragleave', (e) => {
        e.preventDefault();
        e.stopPropagation();
        dragOverlay.classList.remove('opacity-100');
        dragOverlay.classList.add('opacity-0');
      });

      inputContainer.addEventListener('drop', (e) => {
        e.preventDefault();
        e.stopPropagation();
        dragOverlay.classList.remove('opacity-100');
        dragOverlay.classList.add('opacity-0');

        const files = e.dataTransfer?.files;
        if (files && files.length > 0) {
          const file = files[0];
          const isJson = file.name.endsWith('.json') || file.type === 'application/json';
          
          const dot = document.getElementById('status-dot');
          const text = document.getElementById('status-text');
          const badge = document.getElementById('status-badge');
          const jumpBtn = document.getElementById('error-jump');
          const errorDetails = document.getElementById('error-details');

          if (isJson) {
            const reader = new FileReader();
            reader.onload = (event) => {
              const textVal = event.target?.result as string;
              if (editorInput) {
                // Hide input placeholder
                const inPlaceholder = document.getElementById('input-placeholder');
                if (inPlaceholder) {
                  inPlaceholder.classList.remove('opacity-100');
                  inPlaceholder.classList.add('hidden');
                }
                
                editorInput.setValue(textVal);
                validateAndFormat(true);
                editorInput.focus();
              }
            };
            reader.onerror = () => {
              if (dot) dot.className = 'w-2.5 h-2.5 rounded-full bg-error inline-block';
              if (text) text.textContent = 'Read Error';
              if (badge) badge.className = 'flex items-center gap-1.5 text-error font-semibold';
              if (jumpBtn && errorDetails) {
                errorDetails.textContent = `• Error: Failed to read file content`;
                jumpBtn.classList.remove('hidden');
                jumpBtn.removeAttribute('data-line');
                jumpBtn.removeAttribute('data-col');
              }
            };
            reader.readAsText(file);
          } else {
            if (dot) dot.className = 'w-2.5 h-2.5 rounded-full bg-error inline-block';
            if (text) text.textContent = 'Invalid File';
            if (badge) badge.className = 'flex items-center gap-1.5 text-error font-semibold';
            if (jumpBtn && errorDetails) {
              errorDetails.textContent = `• Error: Only JSON files (.json) are supported`;
              jumpBtn.classList.remove('hidden');
              jumpBtn.removeAttribute('data-line');
              jumpBtn.removeAttribute('data-col');
            }
          }
        }
      });
    }
  };

  // Run on mount
  initMonaco();
  setupTriggers();
</script>
