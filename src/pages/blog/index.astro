---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "JSON Workshop Blog & Guides",
  "description": "Educational articles, tutorials, and debugging guides for JSON formatting, validation, and web development.",
  "url": "https://jsonworkshop.com/blog"
};
---

<Layout 
  title="Blog & Tutorials | JSON Workshop" 
  description="Explore comprehensive JSON tutorials, debugging guides, and modern web development best practices from JSON Workshop."
  schemas={[blogSchema]}
>
  <div class="min-h-screen flex flex-col bg-canvas text-ink transition-colors duration-200">
    <Navbar />

    <main class="flex-1 max-w-4xl mx-auto w-full px-6 py-12">
      <!-- Header section -->
      <div class="space-y-4 border-b border-hairline pb-8 mb-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-slate-100 dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-full text-xs font-semibold text-primary">
          <span>📚 Developer Resources</span>
        </div>
        <h1 class="font-sans font-bold text-4xl text-slate-900 dark:text-slate-50 tracking-tight">
          JSON Guides & Tutorials
        </h1>
        <p class="font-sans text-md text-slate-700 dark:text-slate-300 max-w-2xl leading-relaxed">
          In-depth articles, syntax specifications, and practical guides to help developers build, parse, validate, and debug JSON efficiently.
        </p>
      </div>

      <!-- Articles Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {sortedPosts.map((post) => (
          <article class="flex flex-col justify-between border border-hairline bg-paper rounded-lg p-6 hover:border-primary/50 transition-all duration-200 shadow-xs hover:shadow-md group">
            <div class="space-y-3">
              <div class="flex items-center justify-between text-xs text-slate-600 dark:text-slate-400">
                <span class="font-medium px-2 py-0.5 bg-slate-100 dark:bg-slate-800 rounded border border-slate-300 dark:border-slate-700 text-slate-800 dark:text-slate-200">
                  {post.data.category}
                </span>
                <span>{post.data.readTime || '5 min read'}</span>
              </div>

              <h2 class="font-sans font-bold text-xl text-slate-900 dark:text-slate-50 group-hover:text-primary transition-colors duration-150 line-clamp-2">
                <a href={`/blog/${post.id}`} class="focus:outline-none">
                  {post.data.title}
                </a>
              </h2>

              <p class="font-sans text-sm text-slate-700 dark:text-slate-300 leading-relaxed line-clamp-3">
                {post.data.description}
              </p>
            </div>

            <div class="pt-6 mt-4 border-t border-hairline flex items-center justify-between text-xs text-slate-600 dark:text-slate-400">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              <a 
                href={`/blog/${post.id}`} 
                class="font-semibold text-primary inline-flex items-center gap-1 group-hover:translate-x-1 transition-transform duration-150"
              >
                Read Article &rarr;
              </a>
            </div>
          </article>
        ))}
      </div>
    </main>

    <Footer />
  </div>
</Layout>
